# EXO Assistant — Variables d'environnement (Raspberry Pi / Linux)
# Copier ce fichier et adapter les valeurs pour un déploiement Raspberry Pi.

# Clés API (obligatoire)
CLAUDE_API_KEY=your_anthropic_api_key_here
OWM_API_KEY=your_openweathermap_api_key_here

# Home Assistant (optionnel)
HA_URL=http://localhost:8123
HA_TOKEN=your_ha_long_lived_token_here

# Configuration Qt (Linux / Raspberry Pi)
QT_QPA_PLATFORM=eglfs
QT_QUICK_CONTROLS_STYLE=Material
QT_QUICK_CONTROLS_MATERIAL_THEME=Dark

# Audio (Linux)
ALSA_CARD=0
PULSE_RUNTIME_PATH=/run/user/1000/pulse

# Logging
SYSTEM_LOG_LEVEL=INFO

# 🏠 Home Assistant
HA_URL=http://localhost:8123
HA_TOKEN=your_ha_long_lived_token_here
ASSISTANT_CONFIG_DIR=/opt/raspberry-assistant/config
ASSISTANT_LOG_DIR=/var/log/raspberry-assistant