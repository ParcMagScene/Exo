# EXO Assistant - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Clé API Claude (Anthropic)
CLAUDE_API_KEY=sk-ant-api03-VOTRE_CLE_ICI

# Clé API OpenWeatherMap
OWM_API_KEY=VOTRE_CLE_OWM_ICI

# Home Assistant
HA_URL=http://localhost:8123
HA_TOKEN=VOTRE_TOKEN_LONGUE_DUREE_HA

# Chemins EXO (SSD)
EXO_ROOT=D:\EXO
EXO_SSD_ROOT=D:\EXO
EXO_FILES_DIR=D:\EXO\files
HF_HOME=D:\EXO\cache\huggingface
TRANSFORMERS_CACHE=D:\EXO\cache\huggingface\hub
TORCH_HOME=D:\EXO\cache\torch
QT_BIN_PATH=C:\Qt\6.9.3\msvc2022_64\bin
